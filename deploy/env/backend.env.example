# ============================================================
# AdPilot 后端环境变量模板
# 复制为项目根目录的 .env 并填入实际值
# ============================================================

# ── TikTok Marketing API（必填，投放 TikTok 时）──
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_API_BASE_URL=https://business-api.tiktok.com/open_api/v1.3

# ── Meta (Facebook) Marketing API（必填，投放 Meta 时）──
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
# META_API_BASE_URL=https://graph.facebook.com/v21.0  # 可选，有默认值

# ── 产研库 PRD（只读，从已有业务系统读取基础数据）──
PRD_MYSQL_HOST=
PRD_MYSQL_PORT=3306
PRD_MYSQL_USER=
PRD_MYSQL_PASSWORD=
PRD_MYSQL_DATABASE=matrix_advertise

# 旧配置（保留兼容，值与 PRD 相同即可）
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=matrix_advertise

# ── 应用库 APP（读写，AdPilot 系统元数据：用户/权限/模板/面板等）──
APP_MYSQL_HOST=127.0.0.1
APP_MYSQL_PORT=3306
APP_MYSQL_USER=
APP_MYSQL_PASSWORD=
APP_MYSQL_DATABASE=adpilot_app

# ── 业务库 BIZ（读写，AdPilot 业务数据：报表/同步/回传等）──
BIZ_MYSQL_HOST=127.0.0.1
BIZ_MYSQL_PORT=3306
BIZ_MYSQL_USER=
BIZ_MYSQL_PASSWORD=
BIZ_MYSQL_DATABASE=adpilot_biz

# ── JWT 认证（必填）──
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── CORS（可选，生产环境建议填写具体域名）──
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── 服务（可选，有默认值）──
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
