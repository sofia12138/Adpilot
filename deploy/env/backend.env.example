# ============================================================
# AdPilot 后端环境变量模板
# 复制为项目根目录的 .env 并填入实际值
# ============================================================

# ── TikTok Marketing API（必填，投放 TikTok 时）──
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_API_BASE_URL=https://business-api.tiktok.com/open_api/v1.3

# ── Meta (Facebook) Marketing API（必填，投放 Meta 时）──
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
# META_API_BASE_URL=https://graph.facebook.com/v21.0  # 可选，有默认值

# ── 产研库 PRD（只读，从已有业务系统读取基础数据）──
PRD_MYSQL_HOST=
PRD_MYSQL_PORT=3306
PRD_MYSQL_USER=
PRD_MYSQL_PASSWORD=
PRD_MYSQL_DATABASE=matrix_advertise

# 旧配置（保留兼容，值与 PRD 相同即可）
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=matrix_advertise

# ── 应用库 APP（读写，AdPilot 系统元数据：用户/权限/模板/面板等）──
APP_MYSQL_HOST=127.0.0.1
APP_MYSQL_PORT=3306
APP_MYSQL_USER=
APP_MYSQL_PASSWORD=
APP_MYSQL_DATABASE=adpilot_app

# ── 业务库 BIZ（读写，AdPilot 业务数据：报表/同步/回传等）──
BIZ_MYSQL_HOST=127.0.0.1
BIZ_MYSQL_PORT=3306
BIZ_MYSQL_USER=
BIZ_MYSQL_PASSWORD=
BIZ_MYSQL_DATABASE=adpilot_biz

# ── 订单库 ORDER（只读，PolarDB matrix_order，驱动运营面板付费侧实时层/影子表）──
# 任务依赖：sync_ops_polardb_daily、sync_ops_polardb_intraday
# 不配置时这两个任务会静默跳过（PRD/降级模式），其他模块不受影响
ORDER_MYSQL_HOST=
ORDER_MYSQL_PORT=3306
ORDER_MYSQL_USER=
ORDER_MYSQL_PASSWORD=
ORDER_MYSQL_DATABASE=matrix_order

# ── 归因数仓 MaxCompute（用于拉取 metis_dw.ads_ad_delivery_di 等 ADS 层）──
# 凭证建议：阿里云 RAM 子账号，仅授予 metis_dw 项目只读权限
ODPS_ACCESS_KEY_ID=
ODPS_ACCESS_KEY_SECRET=
ODPS_ENDPOINT=https://service.us-west-1.maxcompute.aliyun.com/api
ODPS_PROJECT=metis_dw
# 可选：tunnel 自定义端点（一般不填，pyodps 自动推导）
ODPS_TUNNEL_ENDPOINT=

# ── DMS Enterprise OpenAPI（拉 MC / ClickHouse 实时归因数据）──
# 任务依赖：
#   - sync_attribution_daily   → dbId = DMS_MC_DB_ID（MaxCompute，每日 02:30 跑一次）
#   - sync_attribution_intraday→ dbId = DMS_CK_DB_ID（ClickHouse，每 30 分钟跑一次）
# 鉴权可复用 ODPS_ACCESS_KEY_*；如需独立子账号，用下面这对覆盖
DMS_ACCESS_KEY_ID=
DMS_ACCESS_KEY_SECRET=
DMS_ENDPOINT=dms-enterprise.us-west-1.aliyuncs.com
DMS_MC_DB_ID=
DMS_CK_DB_ID=

# ─── CK D0 实时归因 30min 同步任务总开关 ─────────────────────────
# - true  : lifespan 把 sync_attribution_intraday job 加入调度器（每 30min 跑一次）
# - false : job 完全不注册，前端剧级页/blend 视图在 LA"今天"会无归因
# 历史教训：曾经因为这一行从 .env 丢失，导致服务重启后 5/13 当天前端"无归因"。
# 生产环境务必保留为 true，并在 deploy/update.sh 后做一次配置完整性巡检。
ENABLE_CK_INTRADAY_SYNC=true

# ── JWT 认证（必填）──
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── CORS（可选，生产环境建议填写具体域名）──
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── 服务（可选，有默认值）──
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
