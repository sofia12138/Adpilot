# AdPilot Nginx 配置示例
# 复制本文件到 /etc/nginx/sites-available/adpilot.conf
# 然后 ln -s /etc/nginx/sites-available/adpilot.conf /etc/nginx/sites-enabled/
# 修改 <YOUR_DOMAIN> 和路径后 sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name <YOUR_DOMAIN>;

    # 前端静态文件（npm run build 产物）
    root /var/www/adpilot/frontend/dist;
    index index.html;

    # 请求体大小限制（视频/图片上传）
    client_max_body_size 100m;

    # Gzip
    gzip on;
    gzip_types text/plain application/json application/javascript text/css image/svg+xml;
    gzip_min_length 1024;

    # 前端 SPA 路由回退
    location / {
        try_files $uri $uri/ /index.html;
    }

    # 静态资源缓存
    location /assets/ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # API 反向代理到 FastAPI 后端
    location /api/ {
        proxy_pass http://127.0.0.1:8000/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }

    # Health check
    location /health {
        proxy_pass http://127.0.0.1:8000/health;
        proxy_set_header Host $host;
    }

    # 可选：HTTPS 配置（使用 Let's Encrypt / Certbot）
    # listen 443 ssl;
    # ssl_certificate /etc/letsencrypt/live/<YOUR_DOMAIN>/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/<YOUR_DOMAIN>/privkey.pem;
}
