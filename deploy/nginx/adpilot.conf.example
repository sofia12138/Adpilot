# AdPilot Nginx 配置示例
# 复制本文件到 /etc/nginx/sites-available/adpilot.conf
# 然后 ln -s /etc/nginx/sites-available/adpilot.conf /etc/nginx/sites-enabled/
# 修改 <YOUR_DOMAIN> 和 root 路径后 sudo nginx -t && sudo systemctl reload nginx
#
# 注意：TikTok 大文件上传时，单请求会占用连接直到「浏览器传完 + 后端转发 TikTok 完成」，
# 若 proxy_read_timeout 过短（如 120s），Nginx 会断开连接，前端 XHR 表现为「网络错误」。

server {
    listen 80;
    server_name <YOUR_DOMAIN>;

    # 前端静态文件（deploy/update.sh 将 frontend/dist/* 拷到此处）
    root /var/www/adpilot;
    index index.html;

    # 全站：慢速网络下上传大文件时，避免默认 60s 读 body 中断
    client_max_body_size 1024m;
    client_body_timeout 3600s;
    send_timeout 3600s;

    # Gzip
    gzip on;
    gzip_types text/plain application/json application/javascript text/css image/svg+xml;
    gzip_min_length 1024;

    # 前端 SPA 路由回退
    location / {
        try_files $uri $uri/ /index.html;
    }

    # 静态资源缓存
    location /assets/ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # TikTok 素材上传：必须单独加长超时（须写在通用 /api/ 之前，优先匹配）
    location ^~ /api/materials/tiktok/ {
        proxy_pass http://127.0.0.1:8000/api/materials/tiktok/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_send_timeout 3600s;
        proxy_read_timeout 3600s;
        # 关闭请求缓冲，让后端边收边写入 tmpfs，避免 Nginx 先全量收完再转发
        proxy_request_buffering off;
        # 关闭 Nagle，减少大文件多包时的等待
        tcp_nodelay on;
        # 接收浏览器上传时也尽量直连，避免本地分块缓存翻倍
        client_body_buffer_size 1m;
    }

    # API 反向代理到 FastAPI 后端
    location /api/ {
        proxy_pass http://127.0.0.1:8000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_send_timeout 600s;
        proxy_read_timeout 600s;
    }

    # Health check
    location /health {
        proxy_pass http://127.0.0.1:8000/health;
        proxy_set_header Host $host;
    }

    location /docs {
        proxy_pass http://127.0.0.1:8000/docs;
        proxy_set_header Host $host;
    }

    location /openapi.json {
        proxy_pass http://127.0.0.1:8000/openapi.json;
        proxy_set_header Host $host;
    }

    # 可选：HTTPS 配置（使用 Let's Encrypt / Certbot）
    # listen 443 ssl;
    # ssl_certificate /etc/letsencrypt/live/<YOUR_DOMAIN>/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/<YOUR_DOMAIN>/privkey.pem;
}
