# AdPilot 后端 systemd 服务配置
# 复制到 /etc/systemd/system/adpilot.service
# 修改 <USER>、路径后执行：
#   sudo systemctl daemon-reload
#   sudo systemctl enable adpilot
#   sudo systemctl start adpilot

[Unit]
Description=AdPilot Backend (FastAPI + Uvicorn)
After=network.target mysql.service
Wants=mysql.service

[Service]
Type=simple
User=<USER>
Group=<USER>
WorkingDirectory=/var/www/adpilot/backend
EnvironmentFile=/var/www/adpilot/.env
ExecStart=/var/www/adpilot/venv/bin/uvicorn app:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=adpilot

# 安全加固
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/var/www/adpilot/backend
PrivateTmp=true

[Install]
WantedBy=multi-user.target
